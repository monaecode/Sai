#!/usr/bin/env bash
# agent-scaffold — create a named agent folder (Phase 6 of .ai/INITIALIZE.md).
#
# Usage:
#   agent-scaffold --name NAME --agent-id ID --role-title TITLE \
#                  --principal HUMAN --purpose TEXT --charter PATH \
#                  [--folder-name slug]   # defaults to slugified --name
#                  [--primary-runtime cursor|claude|codex]  # default: cursor
set -euo pipefail

NAME="" AGENT_ID="" ROLE_TITLE="" PRINCIPAL="" PURPOSE="" CHARTER=""
FOLDER="" PRIMARY_RUNTIME="cursor" CONTRACT_ID="" WITH_MEMORY=0
while [ $# -gt 0 ]; do
  case $1 in
    --name) NAME=$2; shift 2;;
    --agent-id) AGENT_ID=$2; shift 2;;
    --role-title) ROLE_TITLE=$2; shift 2;;
    --principal) PRINCIPAL=$2; shift 2;;
    --purpose) PURPOSE=$2; shift 2;;
    --charter) CHARTER=$2; shift 2;;
    --folder-name) FOLDER=$2; shift 2;;
    --primary-runtime) PRIMARY_RUNTIME=$2; shift 2;;
    --contract-id) CONTRACT_ID=$2; shift 2;;
    --with-memory) WITH_MEMORY=1; shift;;
    *) echo "agent-scaffold: unknown option $1" >&2; exit 2;;
  esac
done

[ -n "$AGENT_ID" ] && [ -n "$PRINCIPAL" ] && [ -n "$CHARTER" ] || {
  echo "agent-scaffold: --agent-id, --principal, and --charter are required" >&2; exit 1; }

case "$PRIMARY_RUNTIME" in
  cursor) RUNTIME_ENV="cursor-cloud-vm"; RUNTIME_SUITE="cursor" ;;
  claude) RUNTIME_ENV="claude-code-cli"; RUNTIME_SUITE="claude" ;;
  codex)  RUNTIME_ENV="codex-desktop"; RUNTIME_SUITE="codex" ;;
  *) echo "agent-scaffold: --primary-runtime must be cursor, claude, or codex" >&2; exit 2;;
esac

REPO_ROOT=$(git rev-parse --show-toplevel)
SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=scripts/lib/agent-path-guards.sh
. "$SCRIPT_DIR/lib/agent-path-guards.sh"
slugify() { printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g;s/--*/-/g;s/^-//;s/-$//'; }

guard_agent_id "$AGENT_ID"
guard_charter_path "$REPO_ROOT" "$CHARTER"
[ -z "$CONTRACT_ID" ] || guard_contract_id "$CONTRACT_ID"
[ -z "$NAME" ] || guard_json_safe_string name "$NAME"
[ -z "$ROLE_TITLE" ] || guard_json_safe_string role-title "$ROLE_TITLE"
[ -z "$PURPOSE" ] || guard_json_safe_string purpose "$PURPOSE"

if [ -z "$FOLDER" ]; then
  if printf '%s' "$NAME" | grep -q 'pending'; then
    FOLDER="$AGENT_ID"
  else
    FOLDER=$(slugify "$NAME")
  fi
fi
guard_slug folder-name "$FOLDER"

AGENT_DIR="$REPO_ROOT/.ai/agents/$FOLDER"
guard_under_ai_subtree "$REPO_ROOT" ".ai/agents/$FOLDER" "agents"
CANONICAL_TOOLS="runtimes/${RUNTIME_SUITE}/tools.json"
mkdir -p "$AGENT_DIR/automation" "$AGENT_DIR/runtimes/cursor/automation" \
         "$AGENT_DIR/runtimes/claude/automation" "$AGENT_DIR/runtimes/codex/automation"
TODAY=$(date -u +%Y-%m-%d)

# AGENT.md — runtime-neutral identity card
cat > "$AGENT_DIR/AGENT.md" <<EOF
# ${NAME:-$AGENT_ID}

| | |
|---|---|
| **Name** | ${NAME:-pending Phase 6 grant} |
| **Role title** | ${ROLE_TITLE:-pending Phase 6 grant} |
| **Agent ID** | \`${AGENT_ID}\` |
| **Principal** | ${PRINCIPAL} |
| **Charter** | \`${CHARTER}\` |
| **Folder** | \`.ai/agents/${FOLDER}/\` |
| **Primary runtime** | \`${RUNTIME_ENV}\` |
| **Initialized** | ${TODAY} |

## Purpose and scope

${PURPOSE:-(pending confirmation in Phase 6)}

## Description

SAI agent operating under the coordinated development system. Runtime-neutral
identity card — see \`runtimes/README.md\` and
\`.ai/shared/references/agent-runtimes.md\` for per-runtime invoke paths.

## How to invoke

| Runtime | Entry |
|---|---|
| Cursor | \`@${FOLDER}\` in Cursor Desktop |
| Claude Code | \`CLAUDE.md\` → this folder |
| Codex Desktop | \`CODEX.md\` → this folder |

Slack bots (@Claude, ChatGPT) are not registered agents unless listed in
\`.ai/agents/registry.json\`.

## Files in this folder

| File | Role |
|---|---|
| \`AGENT.md\` | This identity card (load first) |
| \`skills.md\` | Role skills + best practices |
| \`tools.json\` | Manifest → \`${CANONICAL_TOOLS}\` |
| \`hooks.json\` | Git hooks, reporting, triggers |
| \`runtimes/\` | Per-runtime capability suites |
EOF

cat > "$AGENT_DIR/skills.md" <<EOF
# Skills — ${NAME:-$AGENT_ID}

> Fill from Phase 5A best-practice survey. Each skill: what it is, when to
> use it, and the codebase evidence that backs it.

## Core protocol skills (all SAI agents)

- **ICM stage execution** — follow \`.ai/stages/01_intake\` through
  \`06_publish_sync\`; artifacts in \`.ai/runs/<task-id>/\`.
- **Slack reporting** — \`[SAI][EVENT_TYPE][task-id]\` format per
  \`.ai/_config/reporting.yaml\`; queue via \`scripts/agent-report\` when
  offline.
- **Git audit discipline** — commit trailers; \`scripts/verify-agent-audit\`;
  remote-SHA verification after every push.
- **Semantic compliance** — \`scripts/verify-semantic-hierarchy\` before
  protected pushes.

## Role-specific skills

<!-- Add skills unique to this agent's purpose after Phase 5A survey -->
EOF

cat > "$AGENT_DIR/tools.json" <<EOF
{
  "agent_id": "${AGENT_ID}",
  "folder": ".ai/agents/${FOLDER}",
  "primary_runtime": "${RUNTIME_ENV}",
  "canonical_capabilities_path": "${CANONICAL_TOOLS}",
  "surveyed_at": "${TODAY}",
  "environment": "${RUNTIME_ENV}",
  "note": "Manifest only — run scripts/agent-verify-caps against canonical_capabilities_path in Phase 5B",
  "capabilities": []
}
EOF

cat > "$AGENT_DIR/runtimes/${RUNTIME_SUITE}/tools.json" <<EOF
{
  "agent_id": "${AGENT_ID}",
  "folder": ".ai/agents/${FOLDER}",
  "surveyed_at": "${TODAY}",
  "environment": "${RUNTIME_ENV}",
  "capabilities": []
}
EOF

for suite in cursor claude codex; do
  if [ ! -f "$AGENT_DIR/runtimes/$suite/README.md" ]; then
    cat > "$AGENT_DIR/runtimes/$suite/README.md" <<EOF
# ${suite} runtime suite

Primary runtime for this agent: \`${RUNTIME_ENV}\` (${RUNTIME_SUITE}).
Capability file: \`runtimes/${RUNTIME_SUITE}/tools.json\` when this suite is primary.
EOF
  fi
done

cat > "$AGENT_DIR/runtimes/README.md" <<EOF
# Runtime suites — ${NAME:-$AGENT_ID}

Primary runtime: \`${RUNTIME_ENV}\` → \`runtimes/${RUNTIME_SUITE}/\`.

See \`.ai/shared/references/agent-runtimes.md\`.
EOF

cat > "$AGENT_DIR/hooks.json" <<EOF
{
  "agent_id": "${AGENT_ID}",
  "git_hooks": {
    "path": ".githooks",
    "install": "scripts/install-agent-hooks",
    "hooks": ["post-checkout", "post-commit", "post-merge", "post-rewrite", "pre-push", "post-push-equivalent.sh"]
  },
  "cursor_rules": [".cursor/rules/sai-coordination.mdc"],
  "reporting_channels": {
    "agentupdates": "C0BH15HDN2Z",
    "help_newagents": "C0BH8LCJLDS"
  },
  "automation_triggers": {
    "required": [{"type": "scheduled", "note": "baseline protocol upkeep — configure per runtime in Phase 7"}],
    "optional": [
      {"type": "slack", "note": "run on mention in #agentupdates"},
      {"type": "github", "note": "run on PR events"}
    ]
  },
  "ci_enforcement": {
    "workflow": ".github/workflows/agent-audit.yml",
    "verifiers": [
      "scripts/verify-agent-audit",
      "scripts/verify-semantic-hierarchy",
      "scripts/verify-merge-handoff"
    ],
    "merge_handoff": "scripts/ci-merge-handoff-slack",
    "icm_reference": "https://arxiv.org/abs/2603.16021"
  }
}
EOF

echo "agent-scaffold: created $AGENT_DIR (primary-runtime=$PRIMARY_RUNTIME)"
if [ "$WITH_MEMORY" = "1" ] || [ -n "$CONTRACT_ID" ]; then
  MEM_ARGS=(--agent-id "$AGENT_ID" --folder ".ai/agents/$FOLDER")
  [ -n "$CONTRACT_ID" ] && MEM_ARGS+=(--contract-id "$CONTRACT_ID")
  "$REPO_ROOT/scripts/agent-memory-scaffold" "${MEM_ARGS[@]}"
fi
echo "  Next: Phase 5B survey → scripts/agent-verify-caps --tools-file $AGENT_DIR/$CANONICAL_TOOLS --environment $RUNTIME_ENV"
echo "  Phase 7 → scripts/agent-automation-spec --out $AGENT_DIR/runtimes/$RUNTIME_SUITE/automation/profile.md"
